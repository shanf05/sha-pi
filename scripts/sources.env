# Pinned third-party SDR sources, built from source by scripts/build.sh.
#
# These are consumed unmodified: build.sh clones each at the pinned commit into
# build/ (gitignored) and installs into /usr/local. To update, bump the commit
# here (and the note in PROJECT_SUMMARY.md). If we ever need to modify one,
# switch that component to a vendored copy or add a patch step.

RTL_SDR_BLOG_REPO="https://github.com/rtlsdrblog/rtl-sdr-blog"
RTL_SDR_BLOG_COMMIT="aed0ea19f3a273370a13c9009b96313c75d54c7b"

